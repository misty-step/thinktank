{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gradient.local/schemas/readiness-report.schema.json",
  "title": "Gradient Readiness Report",
  "type": "object",
  "required": [
    "id",
    "generated_at",
    "repo_root",
    "rubric",
    "overall",
    "categories",
    "remediations"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "pattern": "^readiness-[a-z0-9-]+$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "repo_root": { "type": "string", "minLength": 1 },
    "rubric": {
      "type": "object",
      "required": ["version", "required_weight", "optional_weight", "reference"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "required_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "optional_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "reference": { "type": "string", "minLength": 1 }
      }
    },
    "overall": {
      "type": "object",
      "required": ["score", "tier"],
      "additionalProperties": false,
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "tier": { "enum": ["low", "functional", "strong", "high"] }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "score", "max_score", "required", "optional", "checks"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "score": { "type": "integer", "minimum": 0, "maximum": 10 },
          "max_score": { "type": "integer", "minimum": 1 },
          "required": {
            "type": "object",
            "required": ["passed", "total"],
            "additionalProperties": false,
            "properties": {
              "passed": { "type": "integer", "minimum": 0 },
              "total": { "type": "integer", "minimum": 0 }
            }
          },
          "optional": {
            "type": "object",
            "required": ["passed", "total"],
            "additionalProperties": false,
            "properties": {
              "passed": { "type": "integer", "minimum": 0 },
              "total": { "type": "integer", "minimum": 0 }
            }
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "title",
                "required",
                "passed",
                "detail",
                "evidence",
                "remediation"
              ],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "title": { "type": "string", "minLength": 1 },
                "required": { "type": "boolean" },
                "passed": { "type": "boolean" },
                "detail": { "type": "string", "minLength": 1 },
                "evidence": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "remediation": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "remediations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "priority", "summary", "rationale", "suggested_evidence"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "priority": { "enum": ["high", "medium"] },
          "summary": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "suggested_evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
