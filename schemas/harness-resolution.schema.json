{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gradient.local/schemas/harness-resolution.schema.json",
  "title": "Gradient Harness Resolution",
  "type": "object",
  "required": ["id", "profile", "primitive_library", "shared_skill_root", "skills", "agents", "bridges"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "profile": { "type": "string", "minLength": 1 },
    "primitive_library": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "enum": ["bundled", "local-path", "git", "org-registry"] },
        "version": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 }
      }
    },
    "shared_skill_root": { "type": "string", "minLength": 1 },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "agents": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "agent_root": { "type": "string", "minLength": 1 },
    "agent_bridges": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "adoption_level": {
      "enum": ["", "harness", "work", "evidence", "policy", "context-fleet", "org-control-plane"]
    },
    "repo_scan": { "type": "string" },
    "bridges": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
