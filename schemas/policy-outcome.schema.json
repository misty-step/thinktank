{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gradient.local/schemas/policy-outcome.schema.json",
  "title": "Gradient Policy Outcome",
  "type": "object",
  "required": ["id", "work_item_id", "fleet_run_id", "verdict", "reasons", "eval_results"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "fleet_run_id": { "type": "string", "minLength": 1 },
    "verdict": { "enum": ["pass", "needs_review", "blocked"] },
    "evidence_verdict": { "enum": ["sufficient", "sufficient_with_risks", "insufficient"] },
    "required_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "missing_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptance_verdict": { "enum": ["proven", "partially_unverified", "failed"] },
    "repo_gate_verdict": { "enum": ["pass", "fail", "unverified", "not_required"] },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "eval_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "summary"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pass", "fail", "unverified"] },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
