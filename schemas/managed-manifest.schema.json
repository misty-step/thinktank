{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gradient Managed Manifest",
  "type": "object",
  "required": ["schema_version", "source_root", "source_version", "generated_at", "files", "repo_owned"],
  "properties": {
    "schema_version": { "const": 1 },
    "source_root": { "type": "string", "minLength": 1 },
    "source_version": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_path",
          "target_path",
          "kind",
          "owner",
          "policy",
          "source_sha256",
          "target_sha256"
        ],
        "properties": {
          "source_path": { "type": "string", "minLength": 1 },
          "target_path": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["file", "symlink"] },
          "owner": { "const": "gradient-managed" },
          "policy": { "const": "update-if-unchanged" },
          "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "target_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "repo_owned": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
