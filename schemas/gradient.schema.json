{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gradient.local/schemas/gradient.schema.json",
  "title": "Gradient Profile",
  "type": "object",
  "required": ["name", "version", "harness", "work", "fleet", "policy", "context"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "extends": { "type": "string" },
    "harness": { "$ref": "#/$defs/harness" },
    "work": { "$ref": "#/$defs/work" },
    "fleet": { "$ref": "#/$defs/fleet" },
    "policy": { "$ref": "#/$defs/policy" },
    "context": { "$ref": "#/$defs/context" },
    "standards": { "$ref": "#/$defs/standards" }
  },
  "$defs": {
    "standards": {
      "type": "object",
      "required": ["baseline", "manifests", "policy_packs", "harness_packs", "exception_policy"],
      "additionalProperties": false,
      "properties": {
        "baseline": { "type": "string", "minLength": 1 },
        "manifests": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "policy_packs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "harness_packs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "exception_policy": {
          "type": "object",
          "required": ["adapter", "required_fields", "expiry_required", "approval_required"],
          "additionalProperties": false,
          "properties": {
            "adapter": { "type": "string", "minLength": 1 },
            "required_fields": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "expiry_required": { "type": "boolean" },
            "approval_required": { "type": "boolean" }
          }
        }
      }
    },
    "harness": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": { "type": "string" },
        "implementation": { "type": "string" },
        "primitive_library": {
          "type": "object",
          "required": ["name", "type"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "type": { "enum": ["bundled", "local-path", "git", "org-registry"] },
            "version": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 },
            "role": { "type": "string", "minLength": 1 }
          }
        },
        "overrides": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "accepted_types": {
              "type": "array",
              "items": { "enum": ["bundled", "local-path", "git", "org-registry"] },
              "uniqueItems": true
            }
          }
        },
        "providers": { "type": "array", "items": { "type": "string" } },
        "allowed_providers": { "type": "array", "items": { "type": "string" } },
        "default_model": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "required_skills": { "type": "array", "items": { "type": "string" } },
        "agents": { "type": "array", "items": { "type": "string" } },
        "agent_root": { "type": "string" },
        "agent_bridges": { "type": "array", "items": { "type": "string" } },
        "default_budget": { "type": "string" }
      }
    },
    "work": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "adapter": { "type": "string" },
        "implementation": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "source": { "type": "string" },
        "requirements": { "type": "object", "additionalProperties": true }
      }
    },
    "fleet": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "backend": { "type": "string" },
        "implementation": { "type": "string" },
        "mode": { "type": "string" },
        "autonomy": { "type": "string" },
        "always_on": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "autonomy": { "type": "string" },
        "approvals": { "type": "object", "additionalProperties": true },
        "audit": { "type": "object", "additionalProperties": true },
        "secrets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "secret_manager": { "type": "string" },
            "secret_access_log": { "type": "string" },
            "rotation_required": { "type": "string" },
            "machine_identity_required": { "type": "string" },
            "secret_values_logged": { "enum": ["forbidden"] }
          }
        },
        "supply_chain": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "package_manager": { "type": "string" },
            "lockfile": { "type": "string" },
            "frozen_installs": { "type": "string" },
            "lifecycle_scripts": { "type": "string" },
            "minimum_release_age_seconds": { "type": "integer", "minimum": 0 },
            "release_age_exceptions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "trace_backend": { "enum": ["local", "raindrop", "langfuse", "helicone", "otlp"] },
            "retention": { "type": "string" },
            "tests": { "type": "string" },
            "verification_commands": { "type": "string" },
            "repo_gate": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "command": { "type": "string" },
                "required": { "type": "boolean" },
                "run_by_default": { "type": "boolean" }
              }
            },
            "review_summary": { "type": "string" }
          }
        },
        "evidence_required": { "type": "array", "items": { "type": "string" } },
        "feedback": { "type": "object", "additionalProperties": true },
        "feedback_destination": { "type": "string" }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sources": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "retrieval": { "type": "object", "additionalProperties": true },
        "citations": { "type": "string" },
        "freshness": { "type": "string" },
        "permissions": { "type": "string" },
        "redaction": { "type": "string" }
      }
    }
  }
}
