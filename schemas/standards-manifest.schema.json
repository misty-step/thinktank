{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gradient.local/schemas/standards-manifest.schema.json",
  "title": "Gradient Standards Manifest",
  "type": "object",
  "required": [
    "id",
    "version",
    "description",
    "baseline_standards",
    "policy_packs",
    "harness_packs",
    "evidence_contracts",
    "exception_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "baseline_standards": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "policy_packs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "harness_packs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_contracts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "exception_policy": {
      "type": "object",
      "required": ["adapter", "required_fields", "expiry_required", "approval_required"],
      "additionalProperties": false,
      "properties": {
        "adapter": { "type": "string", "minLength": 1 },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "expiry_required": { "type": "boolean" },
        "approval_required": { "type": "boolean" }
      }
    }
  }
}
