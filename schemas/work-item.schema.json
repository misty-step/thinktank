{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gradient.local/schemas/work-item.schema.json",
  "title": "Gradient Work Item",
  "type": "object",
  "required": ["id", "title", "status", "lifecycle_stage", "acceptance", "evidence_required"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[0-9]{3}[a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ready", "leased", "blocked", "done", "failed"] },
    "lifecycle_stage": {
      "enum": ["Intent", "Work Graph", "Fleet Run", "Evidence", "Policy/Eval", "Feedback"]
    },
    "owner": { "type": "string", "minLength": 1 },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_required": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
