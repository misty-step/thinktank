{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gradient.local/schemas/context-bundle.schema.json",
  "title": "Gradient Context Bundle",
  "type": "object",
  "required": ["id", "mode", "query", "items"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["assist", "authoritative", "forensics", "chat"] },
    "query": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "body", "source_uri", "freshness", "permission_label", "citation"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "enum": ["fact", "decision", "requirement", "procedure", "evidence"] },
          "body": { "type": "string", "minLength": 1 },
          "source_uri": { "type": "string", "minLength": 1 },
          "source_version": { "type": "string", "minLength": 1 },
          "freshness": { "type": "string", "minLength": 1 },
          "permission_label": { "type": "string", "minLength": 1 },
          "citation": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
