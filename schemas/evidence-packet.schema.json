{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gradient.local/schemas/evidence-packet.schema.json",
  "title": "Gradient Evidence Packet",
  "type": "object",
  "required": [
    "id",
    "work_item_id",
    "harness_id",
    "fleet_run_id",
    "context_bundle_id",
    "policy_outcome_id",
    "artifacts",
    "verification",
    "unverified_claims",
    "reviewer_risks"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "work_item_id": { "type": "string", "minLength": 1 },
    "harness_id": { "type": "string", "minLength": 1 },
    "fleet_run_id": { "type": "string", "minLength": 1 },
    "context_bundle_id": { "type": "string", "minLength": 1 },
    "policy_outcome_id": { "type": "string", "minLength": 1 },
    "workflow_class": {
      "type": "string",
      "minLength": 1,
      "description": "Workflow class whose evidence requirements this packet claims to satisfy."
    },
    "required_artifact_kinds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "trace_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["backend", "trace_id", "redaction", "summary"],
        "additionalProperties": false,
        "anyOf": [
          { "required": ["uri"] },
          { "required": ["artifact_path"] }
        ],
        "properties": {
          "backend": { "enum": ["local", "raindrop", "langfuse", "helicone", "otlp"] },
          "trace_id": { "type": "string", "minLength": 1 },
          "uri": { "type": "string", "minLength": 1 },
          "artifact_path": { "type": "string", "minLength": 1 },
          "redaction": { "enum": ["synthetic", "redacted", "redacted-export", "public-safe"] },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "acceptance_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "status", "artifact_refs", "notes"],
        "additionalProperties": false,
        "properties": {
          "criterion": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pass", "fail", "unverified"] },
          "artifact_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "path", "summary"],
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "status", "summary"],
        "additionalProperties": false,
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["gradient-validation", "repo-gate", "manual-review", "trace-review"] },
          "status": { "enum": ["pass", "fail", "unverified"] },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "unverified_claims": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "reviewer_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
