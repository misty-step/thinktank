name: example-gradient-profile
version: 0.1.0

harness:
  implementation: gradient-native
  profile: base
  primitive_library:
    name: gradient-default
    type: bundled
    version: 0.1.0
    path: .agents/skills
  providers:
    - openai
    - anthropic
  default_model: gpt-5.4
  skills:
    - gradient
    - shape
    - implement
    - code-review
    - qa
    - pr-polish
  agents:
    - planner
    - builder
    - critic
  agent_root: .agents/agents
  agent_bridges:
    - .claude/agents

work:
  implementation: orbital
  aliases:
    - work-adapter-prototype
  adapter: orbital-mcp

fleet:
  implementation: olympus
  backend: olympus
  mode: supervised

policy:
  autonomy: supervised
  evidence:
    trace_backend: local
    retention: public-safe
  evidence_required:
    - tests
    - review-map
    - verification-commands
  feedback_destination: ./feedback.ndjson

context:
  sources:
    - kind: repo
      path: .
    - kind: docs
      path: ./docs
  retrieval:
    mode: assist
    citations: required
