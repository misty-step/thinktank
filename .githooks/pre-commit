#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$REPO_ROOT"

git diff --cached --check

mapfile -t staged_backlog < <(
  git diff --cached --name-only --diff-filter=ACMR | grep -E '^backlog\.d/.*\.md$' || true
)

if command -v pre-commit >/dev/null 2>&1; then
  exec pre-commit run --config .pre-commit-config.yaml --hook-stage pre-commit
fi

if [ "${#staged_backlog[@]}" -gt 0 ]; then
  scripts/ci/backlog-state-gate.sh "${staged_backlog[@]}"
fi

mapfile -t staged_harness_agents < <(
  git diff --cached --name-only --diff-filter=ACMR | grep -E '^\.claude/agents/.*\.md$' || true
)

if [ "${#staged_harness_agents[@]}" -gt 0 ]; then
  scripts/ci/harness-agent-gate.sh
fi

mapfile -t staged_elixir < <(
  git diff --cached --name-only --diff-filter=ACMR | grep -E '\.exs?$' || true
)

if [ "${#staged_elixir[@]}" -eq 0 ]; then
  exit 0
fi

if ! command -v mix >/dev/null 2>&1; then
  echo "pre-commit: install pre-commit or ensure mix is available." >&2
  exit 1
fi

mix format "${staged_elixir[@]}"
scripts/ci/architecture-gate.sh
scripts/validate-elixir-models.sh
git add "${staged_elixir[@]}"
