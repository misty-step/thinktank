# thinktank environment variables
# Copy this file to .env and fill in your values

# OpenRouter API key (get yours at https://openrouter.ai/keys)
# THINKTANK_OPENROUTER_API_KEY takes priority over OPENROUTER_API_KEY.
# Use the thinktank-specific key to track usage separately from other apps.
THINKTANK_OPENROUTER_API_KEY=

# Optional: Test-only variables
# THINKTANK_ENV=test
# THINKTANK_ENABLE_TEST_MODELS=true
# TEST_API_KEY=

# CI environment detection (auto-set by CI systems)
# CI=true
# GITHUB_ACTIONS=true
